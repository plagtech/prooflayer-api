# ProofLayer API — Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# EAS Attestations (optional — for server-side attestation)
EAS_SIGNER_PRIVATE_KEY=
BASE_RPC_URL=https://mainnet.base.org

# API Keys (comma-separated premium keys for validation)
# Free tier works without a key; premium endpoints require one
PREMIUM_API_KEYS=
